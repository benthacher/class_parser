{
    "manifest_version": 2,
    "name": "Class Parser",
    "version": "1.5.4",

    "description": "Add class schedule to calendar!",
    "icons": {
        "512": "icon_512.png"
    },

    "author": "Ben Thacher",
    "browser_action": {
        "default_icon": "icon_512.png",
        "default_title": "Class Parser",
        "default_popup": "popup.html"
    },
    
    "background": {
        "scripts": [ "js/utils.js", "js/background.js" ],
        "persistent": false
    },

    "oauth2": {
        "client_id": "134001920835-2hft9jf2ok0i6oou3qku8t2f4n94mnjf.apps.googleusercontent.com", // tester id
        // "client_id": "273382104694-sd929fq35pauhq0q0q5mpevs650oto0j.apps.googleusercontent.com", // actual id
        "scopes": [
            "https://www.googleapis.com/auth/calendar",
            "https://www.googleapis.com/auth/calendar.events"
        ]
    },
    "permissions": [
        "identity",
        "activeTab"
    ]

}
